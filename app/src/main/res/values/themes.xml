<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#FFB8A07A</item>
        <item name="colorPrimaryVariant">#FF9A8860</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="colorSecondary">#FFD4C4A8</item>
        <item name="colorSecondaryVariant">#FFC4B498</item>
        <item name="colorOnSecondary">#FF3D3A35</item>
        <item name="android:colorBackground">#FFFAF6F0</item>
        <item name="colorSurface">#FFFFFFFF</item>
        <item name="colorOnBackground">#FF3D3A35</item>
        <item name="colorOnSurface">#FF3D3A35</item>
        <item name="android:windowBackground">#FFFAF6F0</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    
    <style name="Theme.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    
    <style name="Theme.FullScreenDialog" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
